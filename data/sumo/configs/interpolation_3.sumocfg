<?xml version='1.0' encoding='utf-8'?>
<configuration>
  <input>
    <net-file value="../base_network/interpolation_3.net.xml" />
    <route-files value="../routes/interpolation_3.rou.xml" />
    <additional-files value="../base_network/interpolation_3.add.xml" />
  </input>
  <time>
    <begin value="0" />
    <end value="3600" />
    <step-length value="1.0" />
  </time>
  <processing>
    <ignore-route-errors value="true" />
    <time-to-teleport value="-1" />
  </processing>
</configuration>